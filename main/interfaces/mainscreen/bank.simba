var
(*
## var Bank
Global Bank variable.
*)
  Bank: TBank;

(*
## GameTabs.Open() override;
```pascal
function TGameTabs.Open(Tab: EGameTab): Boolean; override;
```
Overrides {ref}`GameTabs.Open()` to close the bank if the bank open.
*)
function TGameTabs.Open(Tab: EGameTab): Boolean; override;
begin
  if Bank.IsOpen(False) then
  begin
    if (Tab = EGameTab.INVENTORY) then
      Exit(True);

    Bank.Close();
  end;

  Result := inherited();
end;


function TMainScreen.IsVisible(p: TPoint): Boolean; override;
begin
  Result := inherited;

  if not Result or (GameClient.Mode = EClientMode.FIXED) then
    Exit;

  if Bank.Bounds.Expand(5).Contains(p) and Bank.IsOpen() then
    Exit(False);
end;

function TMainScreen.IsVisible(tpa: TPointArray; useCenter: Boolean = True): Boolean; override;
begin
  Result := inherited;

  if Result and useCenter then
    Exit;

  if not Result or (GameClient.Mode = EClientMode.FIXED) then
    Exit;

  if Bank.Bounds.Expand(5).ContainsAll(tpa) and Bank.IsOpen() then
    Exit(False);
end;

function TMainScreen.Filter(arr: TPointArray): TPointArray; override;
begin
  Result := inherited;

  if (Result = []) or (GameClient.Mode = EClientMode.FIXED) then
    Exit;

  if Bank.IsOpen() then
  begin
    arr := Result.FilterBox(Bank.Bounds);
    Result := Result.Difference(arr);
  end;
end;



procedure TGameClient.ClientModeChanged(); override;
begin
  inherited;
  Bank.SetupAlignment();

  with Bank.Bounds do
  begin
    Bank.TitleBar.X1 := X1 + 30;
    Bank.TitleBar.Y1 := Y1 + 7;
    Bank.TitleBar.X2 := X1 + 120;
    Bank.TitleBar.Y2 := Y1 + 27;

    Bank.SideBar.X1 := X1 + 6;
    Bank.SideBar.Y1 := Y1 + 75;
    Bank.SideBar.X2 := X1 + 43;
    Bank.SideBar.Y2 := Y2 - 47;

    Bank.BottomBar.X1 := X1 + 6;
    Bank.BottomBar.Y1 := Y2 - 43;
    Bank.BottomBar.X2 := X2 - 6;
    Bank.BottomBar.Y2 := Y2 - 6;
  end;
end;

procedure TSRL.Setup(); override;
begin
  inherited;

  Bank.Setup();
end;

procedure TSRL.Debug(Bitmap: TMufasaBitmap); override;
begin
  inherited;

  Bank.Draw(Bitmap);
end;
