function TBank.DepositAll(): Boolean;
var
  btn: TGameButton;
begin
  if not Self.IsOpen() then
    Exit;

  btn := Self.GetButton(EBankDepositButton.INVENTORY);
  if btn = Default(TGameButton) then
  begin
    if not WaitUntil(Self.GetButton(EBankDepositButton.INVENTORY).Visible , 10 , 5000) then
    Self.Fatal('This script needs the "Deposit Inventory" button visible!');
  end;
  Result := (Inventory.Count() = 0) or btn.Click();
end;

